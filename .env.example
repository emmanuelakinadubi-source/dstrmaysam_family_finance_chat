# App
APP_NAME=Event Manager
DEBUG=True
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/family_expense
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=family_expense

# Azure OpenAI  ← REQUIRED for AI venue recommendations and chat
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ChromaDB — local persistent storage (set automatically by Docker)
CHROMA_PERSIST_DIR=/app/chroma_db

# Observability (optional)
# LANGFUSE_HOST     → read by config.py (settings.langfuse_host)
# LANGFUSE_BASE_URL → read by the langfuse v4 Python client directly
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com
MLFLOW_TRACKING_URI=

# AWS (only needed for CD pipeline deployment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-west-2

# Scheduler
VENDOR_CRAWL_HOUR=6
VENDOR_CRAWL_MINUTE=0

# File uploads
UPLOAD_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=50
