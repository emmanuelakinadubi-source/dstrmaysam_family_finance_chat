# App
APP_NAME=Event Manager
DEBUG=True
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/family_finance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=family_finance

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION_FAMILY=family_finance
CHROMA_COLLECTION_COMPANY=company_events

# LLM Provider (openai | anthropic)
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
MLFLOW_TRACKING_URI=

# Scheduler
VENDOR_CRAWL_HOUR=6
VENDOR_CRAWL_MINUTE=0

# File uploads
UPLOAD_DIR=/app/data/uploads
MAX_FILE_SIZE_MB=50
